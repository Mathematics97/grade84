      html += `<div class="card" id="card-${q.id}">
        <div class="card-top">
          <span class="card-num">BLUEPRINT NO. ${String(q.id).padStart(2,'0')}</span>
          <span class="card-status" id="status-${q.id}"></span>
        </div>
        <div class="prompt">${q.type==='expr' ? `Expand and simplify: <span class="expr">${q.prompt}</span>` : q.prompt}</div>
        ${q.note ? `<div class="word-note">${q.note}</div>` : ''}
        ${q.diagram ? `<div class="lot-diagram">${lotDiagramSVG()}</div>` : ''}
        <div class="input-row">
          <input type="text" id="input-${q.id}" placeholder="e.g. 3x^2+5x-2" autocomplete="off" spellcheck="false">
          <button class="primary" onclick="checkAnswer(${q.id})">Check</button>
        </div>
        <div class="action-row">
          <button class="ghost" onclick="toggleHint(${q.id})">💡 Hint</button>
          <button class="ghost" onclick="toggleSolution(${q.id})">📐 Reveal Solution</button>
        </div>
        <div class="hint-box" id="hint-${q.id}">${q.hint}</div>
        <div class="solution-box" id="solution-${q.id}">${buildSolutionHTML(q)}</div>
        <div class="feedback" id="feedback-${q.id}"></div>
      </div>`;
    });
  });
  main.innerHTML = html;
}

function toggleHint(id){
  document.getElementById(`hint-${id}`).classList.toggle('show');
}
function toggleSolution(id){
  document.getElementById(`solution-${id}`).classList.toggle('show');
}

function findQuestion(id){
  for(const level of levels){
    for(const q of level.questions){
      if(q.id === id) return q;
    }
  }
  return null;
}

function checkAnswer(id){
  const q = findQuestion(id);
  const input = document.getElementById(`input-${id}`);
  const feedback = document.getElementById(`feedback-${id}`);
  const userVal = input.value.trim();
  if(userVal===''){
    feedback.className = 'feedback wrong';
    feedback.textContent = 'Type an answer before checking, e.g. 3x^2+5x-2';
    return;
  }
  const userMap = normalizePoly(userVal);
  const answerMap = normalizePoly(q.answer);
  const isCorrect = comparePoly(userMap, answerMap);

  if(userMap === null){
    feedback.className = 'feedback wrong';
    feedback.textContent = "Couldn't read that expression — check you're using ^ for powers and no stray symbols, e.g. 2x^2-x-15";
    return;
  }

  if(isCorrect){
    feedback.className = 'feedback correct';
    feedback.textContent = '✅ Approved! Your expansion is correct.';
    document.getElementById(`card-${id}`).classList.add('solved');
    document.getElementById(`status-${id}`).textContent = '✅';
    solved.add(id);
    updateProgress();
  } else {
    feedback.className = 'feedback wrong';
    feedback.textContent = '❌ Not quite — check your signs and middle term. Try Hint if you\'re stuck.';
  }
}

function updateProgress(){
  const count = solved.size;
  const pct = Math.round((count/TOTAL)*100);
  document.getElementById('progressText').textContent = `${count} / ${TOTAL} BLUEPRINTS APPROVED`;
  document.getElementById('progressPct').textContent = `${pct}%`;
  document.getElementById('progressBar').style.width = `${pct}%`;
  const completeMsg = document.getElementById('completeMsg');
  if(count === TOTAL){
    completeMsg.classList.add('show');
  } else {
    completeMsg.classList.remove('show');
  }
}

/* Allow Enter key to submit */
document.addEventListener('keydown', function(e){
  if(e.key === 'Enter' && e.target.tagName === 'INPUT'){
    const id = parseInt(e.target.id.replace('input-',''));
    if(!isNaN(id)) checkAnswer(id);
  }
});

render();
</script>
</body>
</html>
