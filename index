function buildSolutionHTML(q){
  let html = '';
  q.solution.forEach(([tag,line])=>{
    html += `<div class="step"><span class="tag">${tag}</span>${line}</div>`;
  });
  html += `<div class="final">${q.final}</div>`;
  return html;
}

