/* ---------------- Answer normalization & checking ---------------- */
function normalizePoly(str){
  let s = String(str).toLowerCase().replace(/\s+/g,'');
  s = s.replace(/\*\*/g,'^');
  s = s.replace(/²/g,'^2');
  s = s.replace(/−/g,'-');
  s = s.replace(/^\((.*)\)$/,'$1');
  if(s==='') return null;
  if(s[0]!=='+' && s[0]!=='-') s = '+'+s;
  const termRegex = /[+-][^+-]+/g;
  const terms = s.match(termRegex);
  if(!terms) return null;
  const map = {};
  for(const t of terms){
    const sign = t[0]==='-' ? -1 : 1;
    const body = t.slice(1);
    if(body==='') return null;
    let coeff, degree;
    if(body.includes('x')){
      const parts = body.split('x');
      if(parts.length>2) return null;
      const coefPart = parts[0];
      coeff = coefPart===''?1:parseFloat(coefPart);
      const expPart = parts[1];
      if(expPart && expPart.startsWith('^')){
        degree = parseInt(expPart.slice(1));
      } else if(expPart === ''){
        degree = 1;
      } else {
        return null;
      }
    } else {
      coeff = parseFloat(body);
      degree = 0;
    }
    if(isNaN(coeff) || isNaN(degree)) return null;
    coeff *= sign;
    map[degree] = (map[degree]||0) + coeff;
  }
  return map;
}
function comparePoly(a,b){
  if(!a||!b) return false;
  const keys = new Set([...Object.keys(a),...Object.keys(b)]);
  for(const k of keys){
    const av = a[k]||0, bv=b[k]||0;
    if(Math.abs(av-bv) > 1e-9) return false;
  }
  return true;
}

